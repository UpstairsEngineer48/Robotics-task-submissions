<?xml version="1.0"?>
<robot name="line_follower">

	<link name="chassis">
		<visual>
			<origin xyz="0 0 0.0415" rpy="0 0 0"/>
			<geometry>
				<box size="0.15 0.08 0.003"/>
			</geometry>
			<material name="white">
				<color rgba="1 1 1 1"/>
			</material>
		</visual>
		<collision>
			<origin xyz="0 0 0.0415" rpy="0 0 0"/>
			<geometry>
				<box size="0.15 0.08 0.003"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0.0415" rpy="0 0 0"/>
			<mass value="0.03744"/>
			<inertia ixx="0.0000200" ixy="0" ixz="0" iyy="0.0000312" iyz="0" izz="0.0000512"/>
		</inertial>
	</link>

	<link name="left_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.04" length="0.03"/>
			</geometry>
			<material name="black">
				<color rgba="0 0 0 1"/>
			</material>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.04" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0"/>
			<mass value="0.215"/>
			<inertia ixx="0.000108" ixy="0" ixz="0" iyy="0.000108" iyz="0" izz="0.000172"/>
		</inertial>
	</link>

 
	<link name="right_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.04" length="0.03"/>
			</geometry>
			<material name="black">
				<color rgba="0 0 0 1"/>
			</material>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="1.5708 0 0"/>
			<geometry>
				<cylinder radius="0.04" length="0.03"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0"/>
			<mass value="0.215"/>
			<inertia ixx="0.000108" ixy="0" ixz="0" iyy="0.000108" iyz="0" izz="0.000172"/>
		</inertial>
	</link>
	<link name="center_housing">
		  <visual>
				<geometry>
				  	<cylinder radius="0.025" length="0.02"/>
				</geometry>
				<material name="red">
					<color rgba="1 0 0 1"/>
				</material>
		  </visual>
	</link>

	<link name="center_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<sphere radius="0.02"/>
			</geometry>
			<material name="stainless">
  				<color rgba="0.85 0.85 0.88 1"/>
			</material>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<sphere radius="0.02"/>
			</geometry>
		</collision>
		<inertial>
			<origin xyz="0 0 0"/>
			<mass value="0.05"/>
			<inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
		</inertial>
	</link>

	<joint name="left_wheel_joint" type="continuous">
		<parent link="chassis"/>
		<child link="left_wheel"/>
		<origin xyz="-0.05 0.0575 0.04" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	
	<joint name="right_wheel_joint" type="continuous">
		<parent link="chassis"/>
		<child link="right_wheel"/>
		<origin xyz="-0.05 -0.0575 0.04" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<joint name="housing_joint" type="fixed">
		  <parent link="chassis"/>
		  <child link="center_housing"/>
		  <origin xyz="0.05 0 0.03"/>
	</joint>
	<joint name="center_wheel_joint" type="fixed">
		<parent link="center_housing"/>
		<child link="center_wheel"/>
		<origin xyz="0.00 0 -0.01" rpy="0 0 0"/>
	</joint>
  
  


</robot>


<!--
For the URDF model, five links were created:
1. Chassis
2. Left wheel
3. Right wheel
4. Center housing
5. Center wheel

The left and right wheel joints were defined as continuous joints
because these wheels rotate during robot motion. The center housing
and center wheel were connected using fixed joints to simplify the
caster mechanism while maintaining correct robot movement.

The visual geometry was chosen to resemble the physical robot as
closely as possible. Collision geometry was kept identical to the
visual geometry to simplify the model while maintaining reasonable
collision behavior.

Mass values for the chassis and drive wheels were calculated using
their dimensions and estimated material densities. The corresponding
inertia tensors were then calculated using standard formulas.
Approximate values were assigned to the center housing and center
wheel due to the lack of accurate physical specifications.

The inertial origins were placed near the estimated centers of mass.
A vertical offset of 0.0415 m was used to position the chassis
correctly above the ground and prevent ground penetration when the
robot is spawned in Gazebo.

The relative placement of all links was defined using joint origin
tags, which specify the position and orientation of each child link
with respect to its parent link.
-->
